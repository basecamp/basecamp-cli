# QA Allowlist — unverifiable tests that do not block release.
# Each line: test name followed by # reason and owner.
# Entries expire each release cycle — review and close gaps.
#
# Format: <test name> # <reason> — <owner>

# Dock tools may be disabled on the test project
test_todolistgroups_show_returns_group_detail # no todolist groups in project
test_tools_show_returns_a_tool # depends on messageboard dock tool
test_schedule_settings_updates_schedule_settings # schedule dock tool disabled

# Message types / inbox may not exist in all environments
test_messagetypes_list_returns_message_types # API returns not_found on some servers
test_messagetypes_show_returns_message_type_detail # depends on messagetypes list
test_forwards_inbox_shows_project_inbox # inbox dock tool disabled
test_forwards_list_returns_forwards # inbox dock tool disabled
test_forwards_show_returns_forward_detail # inbox dock tool disabled

# Features not available in all accounts
test_search_metadata_returns_metadata # requires projects with search enabled
test_reports_schedule_returns_schedule_entries # 400 on some environments
test_timesheet_report_returns_timesheet_data # timesheets not enabled
test_timesheet_project_returns_project_timesheet # timesheets not enabled

# Lineup API may not exist on all environments / returns 204 No Content
test_lineup_create_creates_a_lineup_marker # API not available on some servers
test_lineup_update_updates_a_lineup_marker # create returns no ID
test_lineup_delete_removes_a_lineup_marker # create returns no ID

# SDK bug: TodolistOrGroup0 union type expects wrapped JSON, API returns flat
test_todolists_show_returns_todolist_detail # SDK deserialization mismatch
